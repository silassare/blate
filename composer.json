{
	"name": "silassare/blate",
	"description": "Blate template engine for php.",
	"type": "library",
	"license": "MIT",
	"keywords": [
		"blate",
		"template",
		"php",
		"website"
	],
	"homepage": "https://github.com/silassare/blate#readme",
	"require": {
		"php": ">=8.1",
		"ext-json": "*",
		"silassare/php-utils": "^2.0.0"
	},
	"require-dev": {
		"roave/security-advisories": "dev-latest",
		"oliup/oliup-cs-php": "dev-main",
		"phpunit/phpunit": "^9.5.26",
		"vimeo/psalm": "^6.0"
	},
	"repositories": {
		"oliup/oliup-cs-php": {
			"type": "vcs",
			"url": "https://github.com/oliup-io/oliup-cs-php"
		},
		"silassare/php-utils": {
			"type": "vcs",
			"url": "https://github.com/silassare/php-utils"
		}
	},
	"archive": {
		"exclude": [
			"/tests",
			"/editors/vscode/node_modules"
		]
	},
	"autoload": {
		"psr-4": {
			"Blate\\": "src/"
		},
		"files": [
			"src/bootstrap.php"
		]
	},
	"autoload-dev": {
		"psr-4": {
			"Blate\\Tests\\": "tests/"
		}
	},
	"authors": [
		{
			"name": "Emile Silas Sare",
			"homepage": "https://github.com/silassare"
		}
	],
	"prefer-stable": true,
	"minimum-stability": "dev",
	"extra": {
		"branch-alias": {
			"dev-main": "1.x-dev"
		}
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
