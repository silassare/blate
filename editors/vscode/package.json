{
	"name": "blate",
	"displayName": "Blate Template",
	"description": "Syntax highlighting and Language Server for Blate template files (.blate)",
	"version": "1.0.0",
	"publisher": "silassare",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/silassare/blate"
	},
	"engines": {
		"vscode": "^1.60.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [
		"onLanguage:blate"
	],
	"main": "./out/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "blate",
				"aliases": [
					"Blate",
					"blate"
				],
				"extensions": [
					".blate"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "blate",
				"scopeName": "text.html.blate",
				"path": "./syntaxes/blate.tmLanguage.json",
				"embeddedLanguages": {
					"source.php": "php",
					"text.html.basic": "html"
				}
			}
		],
		"configuration": {
			"title": "Blate",
			"properties": {
				"blate.phpExecutable": {
					"type": "string",
					"default": "php",
					"description": "Path to the PHP executable used to run the Blate language server."
				}
			}
		}
	},
	"scripts": {
		"compile": "node esbuild.js",
		"watch": "node esbuild.js --watch",
		"vscode:prepublish": "node esbuild.js --minify"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^20.0.0",
		"@types/vscode": "^1.60.0",
		"esbuild": "^0.25.0",
		"vscode-languageclient": "^9.0.1"
	}
}
