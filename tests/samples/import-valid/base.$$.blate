<!DOCTYPE html>
<html lang="{lang}">
	<head>
		<title>{@slot title}Blabla WebSite{/slot}</title>
	</head>
	<body>
		{@slot body}Welcome to Blabla WebSite{/slot}
		<ul>
			{@each value:key:index in data.fruits}
			    <li>{@slot item} {index} - {value} {/slot}</li>
			{/each}
        </ul>
	</body>
</html>
